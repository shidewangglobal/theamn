---
---

<section id="contact" class="section-dark relative py-24 md:py-32">
  <div class="grain-overlay absolute inset-0"></div>

  <div class="relative mx-auto max-w-7xl px-6 md:px-8">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
      <div>
        <p class="reveal section-label mb-4 !text-amn-lime">Contact</p>
        <h2 class="reveal font-headline-bold mb-6 text-3xl text-white md:text-4xl lg:text-5xl">Let's elevate your brand</h2>
        <p class="reveal font-body-secondary mb-10 text-lg leading-relaxed text-white/65">
          For more in-depth conversations about how THE AMN can elevate your premium hospitality brand,
          reach out to our team. We'd love to explore how authentic storytelling, agile operations,
          and accelerated performance can transform your digital presence.
        </p>

        <div class="reveal bento-solid-cream bento-p-md">
          <h3 class="font-headline-bold mb-6 text-xl text-amn-dark">The AMN Limited</h3>
          <dl class="space-y-4 font-body-secondary text-amn-brown/80">
            <div>
              <dt class="font-caption mb-1 text-xs uppercase tracking-wider text-amn-blue">Contact Person</dt>
              <dd class="text-lg text-amn-dark">Dat Vuong</dd>
            </div>
            <div>
              <dt class="font-caption mb-1 text-xs uppercase tracking-wider text-amn-blue">Email</dt>
              <dd>
                <a href="mailto:dat.vuong@theamn.network" class="text-amn-blue transition hover:text-amn-dark">
                  dat.vuong@theamn.network
                </a>
              </dd>
            </div>
            <div>
              <dt class="font-caption mb-1 text-xs uppercase tracking-wider text-amn-blue">Phone</dt>
              <dd>
                <a href="tel:+84905930309" class="text-amn-blue transition hover:text-amn-dark">+84 905 930 309</a>
              </dd>
            </div>
            <div>
              <dt class="font-caption mb-1 text-xs uppercase tracking-wider text-amn-blue">Core Hub</dt>
              <dd>Ho Chi Minh City, Vietnam</dd>
            </div>
            <div>
              <dt class="font-caption mb-1 text-xs uppercase tracking-wider text-amn-blue">Website</dt>
              <dd>
                <a href="https://theamn.network" class="text-amn-blue transition hover:text-amn-dark" target="_blank" rel="noopener noreferrer">theamn.network</a>
              </dd>
            </div>
          </dl>
        </div>
      </div>

      <div class="reveal bento-solid bento-p-md md:p-10">
        <h3 class="font-headline-bold mb-2 text-2xl text-amn-dark">Send a message</h3>
        <p class="font-body-secondary mb-8 text-sm text-amn-brown/60">We'll get back to you within 1-2 business days.</p>

        <form class="space-y-5" action="https://formspree.io/f/placeholder" method="POST">
          <div>
            <label for="name" class="font-caption mb-2 block text-xs uppercase tracking-wider text-amn-brown/70">Name</label>
            <input type="text" id="name" name="name" required class="form-input" placeholder="Your name" />
          </div>
          <div>
            <label for="email" class="font-caption mb-2 block text-xs uppercase tracking-wider text-amn-brown/70">Email</label>
            <input type="email" id="email" name="email" required class="form-input" placeholder="you@company.com" />
          </div>
          <div>
            <label for="company" class="font-caption mb-2 block text-xs uppercase tracking-wider text-amn-brown/70">Property / Company</label>
            <input type="text" id="company" name="company" class="form-input" placeholder="Your hotel or resort" />
          </div>
          <div>
            <label for="message" class="font-caption mb-2 block text-xs uppercase tracking-wider text-amn-brown/70">Message</label>
            <textarea id="message" name="message" rows="5" required class="form-input resize-none" placeholder="Tell us about your property or project..."></textarea>
          </div>
          <button type="submit" class="btn-primary w-full">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>
