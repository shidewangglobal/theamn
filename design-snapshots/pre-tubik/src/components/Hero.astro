---
---

<section id="hero" class="section-dark relative flex min-h-screen items-center overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-amn-dark via-[#111] to-amn-teal/40"></div>
  <div class="hero-glow absolute inset-0"></div>
  <div class="grain-overlay absolute inset-0"></div>

  <div
    class="hero-glow-orb pointer-events-none absolute left-1/2 top-1/3 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-40"
    style="background: radial-gradient(circle, rgba(0,160,240,0.4) 0%, transparent 70%);"
  ></div>
  <div
    class="hero-glow-orb-lime pointer-events-none absolute right-[10%] top-[55%] h-[300px] w-[300px] rounded-full opacity-25"
    style="background: radial-gradient(circle, rgba(212,230,0,0.3) 0%, transparent 70%);"
  ></div>

  <img
    src="/images/hero-cover.jpeg"
    alt=""
    class="absolute inset-0 h-full w-full object-cover opacity-20 mix-blend-luminosity"
    loading="eager"
    aria-hidden="true"
  />

  <div class="relative z-10 mx-auto flex w-full max-w-7xl flex-col items-center px-6 pb-24 pt-32 text-center md:px-8 md:pt-40">
    <p class="hero-wordmark font-headline mb-10 text-4xl lowercase tracking-[0.35em] text-white md:text-5xl">
      the amn
    </p>

    <p class="hero-tagline section-label mb-6 !text-amn-lime">
      <span class="text-accent-italic">Authentic.</span> <span class="text-accent-italic">Agile.</span> <span class="text-accent-italic">Accelerated.</span>
    </p>

    <h1 class="hero-headline font-headline-bold max-w-4xl text-4xl leading-[1.1] text-white md:text-6xl lg:text-7xl">
      <span class="text-reveal-line block">Transforming boundaries</span>
      <span class="text-reveal-line block text-accent-italic">into brand possibilities</span>
    </h1>

    <p class="hero-sub mx-auto mt-8 max-w-2xl font-body-secondary text-lg text-white/70 md:text-xl">
      Elevating multi-market revenue and direct bookings for premium hotels and resorts,
      harmonizing luxury-taste expertise with AI-driven digital marketing operations.
    </p>

    <div class="hero-cta mt-12 flex flex-wrap items-center justify-center gap-4">
      <a href="#contact" class="pill-nav-link btn-primary">Start a Conversation</a>
      <a href="#services" class="pill-nav-link btn-outline">Explore Services</a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 z-10 -translate-x-1/2">
    <a href="#about" class="pill-nav-link flex flex-col items-center gap-2 text-white/40 transition hover:text-white/70" aria-label="Scroll to about">
      <span class="font-caption text-[10px] uppercase tracking-[0.3em]">Scroll</span>
      <svg class="h-5 w-5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
      </svg>
    </a>
  </div>
</section>
