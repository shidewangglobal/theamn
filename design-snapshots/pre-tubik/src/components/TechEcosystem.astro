---
---

<section id="tech" class="section-dark relative overflow-hidden py-24 md:py-32">
  <div class="grain-overlay absolute inset-0"></div>
  <div class="absolute right-0 top-0 h-[400px] w-[400px] rounded-full opacity-20" style="background: radial-gradient(circle, rgba(0,160,240,0.3) 0%, transparent 70%);"></div>

  <div class="relative mx-auto max-w-7xl px-6 md:px-8">
    <div class="mb-16 text-center">
      <p class="reveal section-label mb-4 !text-amn-lime">Technology Ecosystem</p>
      <h2 class="reveal font-headline-bold mx-auto max-w-3xl text-3xl text-white md:text-4xl lg:text-5xl">
        Powered by <span class="headline-italic">Advant Labs</span>
      </h2>
      <p class="reveal mx-auto mt-6 max-w-2xl font-body-secondary text-white/60">
        THE AMN is proudly a strategic partner of Advant Labs, the central intelligence and technology
        within the luxury hospitality ecosystem.
      </p>
    </div>

    <div class="reveal-stagger bento-grid lg:grid-cols-2">
      <div class="tech-block bento-grid">
        <div class="tech-image-box bento-image">
          <img src="/images/tech-ecosystem.jpeg" alt="Advant Labs technology ecosystem" class="aspect-video w-full object-cover lg:aspect-[4/3]" loading="lazy" />
        </div>
        <article class="tech-text-card bento-solid-cream bento-p-md">
          <p class="font-caption mb-2 text-xs tracking-[0.2em] text-amn-blue">Advant Labs</p>
          <h3 class="font-headline-bold mb-4 text-2xl text-amn-dark">Central Intelligence & Technology</h3>
          <p class="font-body-secondary leading-relaxed text-amn-brown/70">
            The central intelligence and technology within the luxury hospitality ecosystem, developing
            advanced proprietary AI engines, automated workflows, and operating systems that deploy next-gen
            intelligence to maximize analytical and tactical speed.
          </p>
        </article>
      </div>

      <div class="tech-block bento-grid">
        <div class="tech-image-box bento-image">
          <img src="/images/brand-transform-visual.png" alt="THE AMN integrated operational stack" class="aspect-video w-full object-cover lg:aspect-[4/3]" loading="lazy" />
        </div>
        <article class="tech-text-card bento-solid-cream bento-p-md">
          <p class="font-caption mb-2 text-xs tracking-[0.2em] text-amn-blue">THE AMN</p>
          <h3 class="font-headline-bold mb-4 text-2xl text-amn-dark">Strategic Marketing Network</h3>
          <p class="font-body-secondary leading-relaxed text-amn-brown/70">
            The strategic marketing professionals network handling full brand marketing from strategy to execution,
            utilizing AI-empowered solutions to scale up marketing campaigns while automation drives operational
            acceleration and deep portfolio expertise verifies accurate, business-aligned results.
          </p>
        </article>
      </div>
    </div>
  </div>
</section>
