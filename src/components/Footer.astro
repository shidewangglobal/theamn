---
const year = new Date().getFullYear();
---

<footer class="section-dark border-t border-white/10">
  <div class="footer-bar mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-x-6 gap-y-3 px-6 py-5 md:px-8">
    <a href="#" class="shrink-0">
      <img src="/assets/amn-logo-header-light.png" alt="the amn" class="h-7 w-auto opacity-90 md:h-8" width="160" height="48" />
    </a>

    <nav class="footer-nav flex flex-wrap items-center gap-5 md:gap-6" aria-label="Footer navigation">
      <a href="#about" class="pill-nav-link font-caption text-xs uppercase tracking-wider text-white/50 transition hover:text-white">About</a>
      <a href="#services" class="pill-nav-link font-caption text-xs uppercase tracking-wider text-white/50 transition hover:text-white">Services</a>
      <a href="#contact" class="pill-nav-link font-caption text-xs uppercase tracking-wider text-white/50 transition hover:text-white">Connect</a>
    </nav>

    <div class="footer-meta flex flex-wrap items-center gap-x-3 gap-y-1 font-caption text-xs text-white/40">
      <span>&copy; {year} The AMN Limited</span>
      <span class="hidden text-white/20 sm:inline" aria-hidden="true">·</span>
      <a href="https://theamn.network" class="transition hover:text-amn-blue">theamn.network</a>
    </div>
  </div>
</footer>

<style>
  .footer-bar {
    row-gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .footer-nav {
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
