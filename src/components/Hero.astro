---
const heroAWords = [
  'Agile',
  'Accelerated',
  'Authentic',
  'Artistic',
  'Adaptive',
  'Astute',
  'Amplified',
];

const heroAWordMax = heroAWords.reduce(
  (longest, word) => (word.length > longest.length ? word : longest),
  heroAWords[0],
);

const heroVideos = [
  { src: '/videos/hero-banner-1.mov', label: 'Hero background video 1' },
  { src: '/videos/hero-banner-2.mov', label: 'Hero background video 2' },
];
---

<section id="hero" class="tubik-section pt-24 md:pt-28">
  <div class="tubik-shell">
    <div class="hero-panel bento-image relative min-h-[min(88vh,920px)] overflow-hidden">
      <div class="hero-media-layer absolute inset-0 overflow-hidden" aria-hidden="true">
        {heroVideos.map((video, i) => (
          <video
            class:list={['hero-video-bg', i === 0 ? 'hero-video-a is-active' : 'hero-video-b']}
            autoplay={i === 0}
            muted
            loop
            playsinline
            preload="auto"
            poster="/images/hero-cover.jpeg"
            data-hero-video-index={i}
          >
            <source src={video.src} type="video/mp4" />
            <source src={video.src} type="video/quicktime" />
          </video>
        ))}
        <img
          src="/images/hero-cover.jpeg"
          alt=""
          class="hero-fallback-img absolute inset-0 h-full w-full object-cover opacity-30 mix-blend-luminosity"
          loading="eager"
        />
      </div>

      <div class="hero-overlay-stack absolute inset-0 z-[1]">
        <div class="hero-panel-blue absolute inset-0"></div>
        <div class="hero-gradient absolute inset-0 bg-gradient-to-b from-amn-dark/55 via-[#0c1a2e]/45 to-amn-dark/75"></div>
        <div class="hero-glow hero-panel-glow absolute inset-0"></div>
        <div class="grain-overlay absolute inset-0"></div>
      </div>

      <div class="hero-content relative z-10 flex min-h-[min(88vh,920px)] flex-col items-center justify-center px-6 pt-20 text-center md:px-12 md:pt-24">
        <h1 class="hero-headline bento-on-image mx-auto font-headline text-[clamp(1.35rem,4.2vw,3.75rem)] font-light leading-[1.32] tracking-tight text-white">
          <span class="hero-headline-line inline-flex items-baseline">
            <span class="hero-headline-static shrink-0">The&nbsp;</span>

            <span class="hero-a-slot inline-grid shrink-0">
              <span class="hero-a-slot-measure headline-italic text-amn-lime" aria-hidden="true">
                {heroAWordMax}
              </span>
              <span
                class="hero-a-viewport col-start-1 row-start-1"
                aria-live="polite"
                aria-atomic="true"
              >
                <span
                  class="hero-a-word headline-italic text-amn-lime"
                  data-hero-a-words={JSON.stringify(heroAWords)}
                >
                  {heroAWords[0]}
                </span>
              </span>
            </span>

            <span class="hero-headline-static shrink-0">&nbsp;Marketing Network</span>
          </span>
        </h1>

        <p class="hero-tagline bento-on-image mx-auto mt-8 max-w-2xl font-body-secondary text-base italic leading-relaxed text-white md:mt-10 md:text-lg lg:text-xl">
          Every luxury brand holds a unique legacy and should be flawlessly activated across platforms and regions,
          powered by deep marketing expertise.
        </p>

        <div class="hero-cta mt-10 flex flex-wrap items-center justify-center gap-3 md:mt-12 md:gap-4">
          <a href="#contact" class="pill-nav-link btn-primary">Start a Conversation</a>
          <a href="#services" class="pill-nav-link btn-outline">Explore Services</a>
        </div>

        <a
          href="#about"
          class="hero-scroll pill-nav-link bento-on-image mt-14 flex flex-col items-center gap-2 text-white/50 transition hover:text-white/80 md:mt-20"
          aria-label="Scroll to about"
        >
          <span class="font-caption text-[10px] uppercase tracking-[0.3em]">Scroll</span>
          <svg class="h-5 w-5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const videos = document.querySelectorAll<HTMLVideoElement>('.hero-video-bg');
  const heroFallback = document.querySelector<HTMLImageElement>('.hero-fallback-img');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const showFallback = () => {
    videos.forEach((v) => v.classList.add('is-hidden'));
    heroFallback?.classList.add('is-visible');
  };

  if (reducedMotion) {
    showFallback();
  } else if (videos.length) {
    videos[0]?.play().catch(showFallback);
    videos.forEach((v) => v.addEventListener('error', showFallback));
  }
</script>

<style>
  .hero-media-layer {
    z-index: 0;
  }

  .hero-video-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-video-bg.is-active {
    opacity: 1;
  }

  .hero-video-bg.is-hidden {
    display: none;
  }

  .hero-fallback-img {
    opacity: 0;
    pointer-events: none;
  }

  .hero-fallback-img.is-visible {
    opacity: 0.3;
  }

  .hero-overlay-stack {
    opacity: 0.6;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video-bg {
      display: none;
    }

    .hero-fallback-img.is-visible {
      opacity: 0.3;
    }
  }

  .hero-panel-blue {
    background: radial-gradient(
      ellipse 70% 60% at 50% 45%,
      rgba(0, 160, 240, 0.18) 0%,
      rgba(28, 70, 83, 0.12) 45%,
      transparent 72%
    );
  }

  .hero-panel-glow {
    background: radial-gradient(
      ellipse 55% 45% at 50% 38%,
      rgba(0, 160, 240, 0.15) 0%,
      transparent 68%
    );
  }

  .hero-headline-line {
    white-space: nowrap;
  }

  .hero-a-slot {
    vertical-align: baseline;
  }

  .hero-a-slot-measure {
    visibility: hidden;
    grid-area: 1 / 1;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
  }

  .hero-a-viewport {
    grid-area: 1 / 1;
    display: flex;
    align-items: baseline;
    justify-content: center;
    overflow: hidden;
    line-height: inherit;
  }

  .hero-a-word {
    display: inline-block;
    line-height: inherit;
    will-change: transform, opacity, filter;
  }
</style>
