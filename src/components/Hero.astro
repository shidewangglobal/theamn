---
const heroAWords = [
  'Agile',
  'Accelerated',
  'Authentic',
  'Artistic',
  'Aesthetic',
  'Adaptive',
  'Advanced',
  'Amplified',
];

const heroAWordMax = heroAWords.reduce(
  (longest, word) => (word.length > longest.length ? word : longest),
  heroAWords[0],
);

const heroVideos = [
  {
    mp4: '/videos/hero-banner-2.mp4',
    mov: '/videos/hero-banner-2.mov',
    label: 'Hero background video 2',
  },
  {
    mp4: '/videos/hero-banner-1.mp4',
    mov: '/videos/hero-banner-1.mov',
    label: 'Hero background video 1',
  },
];
---

<section id="hero" class="tubik-section pt-24 md:pt-28">
  <div class="tubik-shell">
    <div class="hero-panel bento-image relative min-h-[min(88vh,920px)] overflow-hidden">
      <div class="hero-media-layer absolute inset-0 overflow-hidden" aria-hidden="true">
        {heroVideos.map((video, i) => (
          <video
            class:list={['hero-video-bg', i === 0 ? 'hero-video-a is-active' : 'hero-video-b']}
            src={video.mp4}
            data-hero-fallback-src={video.mov}
            autoplay={i === 0}
            muted
            loop
            playsinline
            preload={i === 0 ? 'auto' : 'metadata'}
            poster="/images/hero-cover.jpeg"
            data-hero-video-index={i}
            aria-label={video.label}
          />
        ))}
        <img
          src="/images/hero-cover.jpeg"
          alt=""
          class="hero-fallback-img absolute inset-0 h-full w-full object-cover opacity-30 mix-blend-luminosity"
          loading="eager"
        />
      </div>

      <div class="hero-overlay-stack absolute inset-0 z-[1]">
        <div class="hero-scrim absolute inset-0" aria-hidden="true"></div>
        <div class="hero-grain absolute inset-0" aria-hidden="true"></div>
      </div>

      <div class="hero-content relative z-10 flex min-h-[min(88vh,920px)] flex-col items-center justify-center px-6 pt-20 text-center md:px-12 md:pt-24">
        <h1 class="hero-headline bento-on-image mx-auto font-headline text-[clamp(1.35rem,4.2vw,3.75rem)] font-light leading-[1.32] tracking-tight text-white">
          <span class="hero-headline-line inline-flex items-baseline">
            <span class="hero-headline-static shrink-0">The&nbsp;</span>

            <span class="hero-a-slot inline-grid shrink-0">
              <span class="hero-a-slot-measure headline-italic text-amn-lime" aria-hidden="true">
                {heroAWordMax}
              </span>
              <span
                class="hero-a-viewport col-start-1 row-start-1"
                aria-live="polite"
                aria-atomic="true"
              >
                <span
                  class="hero-a-word headline-italic text-amn-lime"
                  data-hero-a-words={JSON.stringify(heroAWords)}
                >
                  {heroAWords[0]}
                </span>
              </span>
            </span>

            <span class="hero-headline-static shrink-0">&nbsp;Marketing Network</span>
          </span>
        </h1>

        <p class="hero-tagline bento-on-image mx-auto mt-8 max-w-2xl font-body-secondary text-base italic leading-relaxed text-white md:mt-10 md:text-lg lg:text-xl">
          Every luxury brand holds a unique legacy and should be flawlessly activated across platforms and regions,
          powered by deep marketing expertise.
        </p>

        <div class="hero-cta mt-10 flex flex-wrap items-center justify-center gap-3 md:mt-12 md:gap-4">
          <a href="#contact" class="pill-nav-link btn-primary">Start a Conversation</a>
          <a href="#services" class="pill-nav-link btn-outline">Explore Services</a>
        </div>

        <a
          href="#about"
          class="hero-scroll pill-nav-link bento-on-image mt-14 flex flex-col items-center gap-2 text-white/50 transition hover:text-white/80 md:mt-20"
          aria-label="Scroll to about"
        >
          <span class="font-caption text-[10px] uppercase tracking-[0.3em]">Scroll</span>
          <svg class="h-5 w-5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reducedMotion) return;

    function primeVideo(video) {
      if (!video) return;
      video.muted = true;
      video.defaultMuted = true;
      video.setAttribute('muted', '');
      video.setAttribute('playsinline', '');
      video.setAttribute('webkit-playsinline', '');
      video.playsInline = true;
    }

    function markPlaying(video) {
      video.classList.add('is-playing');
    }

    function tryPlay(video) {
      primeVideo(video);
      var promise = video.play();
      if (!promise || !promise.then) {
        if (!video.paused) markPlaying(video);
        return;
      }
      promise
        .then(function () {
          markPlaying(video);
        })
        .catch(function () {
          if (!video.paused) markPlaying(video);
        });
    }

    function swapToFallback(video) {
      var fallback = video.getAttribute('data-hero-fallback-src');
      if (!fallback || video.dataset.heroSwapped === 'true') return;
      video.dataset.heroSwapped = 'true';
      video.src = fallback;
      video.load();
      tryPlay(video);
    }

    function bootHeroVideos() {
      var videos = document.querySelectorAll('.hero-video-bg');
      if (!videos.length) return;

      var first = videos[0];
      primeVideo(first);

      if (first.readyState >= 2) tryPlay(first);
      else first.addEventListener('canplay', function () { tryPlay(first); }, { once: true });

      first.addEventListener('error', function () { swapToFallback(first); }, { once: true });

      function resumeOnGesture() {
        videos.forEach(function (video) {
          if (video.paused) tryPlay(video);
        });
      }

      window.addEventListener('touchstart', resumeOnGesture, { once: true, passive: true });
      window.addEventListener('click', resumeOnGesture, { once: true });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootHeroVideos);
    } else {
      bootHeroVideos();
    }
  })();
</script>

<style>
  .hero-media-layer {
    z-index: 0;
  }

  .hero-video-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-video-bg.is-active,
  .hero-video-bg.is-playing {
    opacity: 1;
  }

  .hero-video-bg.is-hidden {
    display: none;
  }

  .hero-fallback-img {
    opacity: 0;
    pointer-events: none;
  }

  .hero-fallback-img.is-visible {
    opacity: 0.3;
  }

  .hero-overlay-stack {
    pointer-events: none;
  }

  /* Transparent blue-black only — video stays visible, no gray/white wash */
  .hero-scrim {
    background:
      radial-gradient(
        ellipse 110% 90% at 50% 42%,
        rgba(8, 18, 32, 0.42) 0%,
        rgba(5, 12, 22, 0.54) 55%,
        rgba(3, 8, 16, 0.61) 100%
      ),
      linear-gradient(
        180deg,
        rgba(6, 14, 26, 0.46) 0%,
        rgba(8, 20, 36, 0.53) 50%,
        rgba(4, 10, 20, 0.59) 100%
      );
  }

  .hero-grain {
    pointer-events: none;
  }

  .hero-grain::before,
  .hero-grain::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 220px 220px;
    pointer-events: none;
  }

  /* Blue grain */
  .hero-grain::before {
    opacity: 0.16;
    mix-blend-mode: overlay;
    background-color: rgba(0, 130, 195, 0.5);
    background-blend-mode: overlay;
    filter: contrast(1.3) brightness(0.88);
  }

  /* Warm orange grain — slight offset for chromatic feel */
  .hero-grain::after {
    opacity: 0.12;
    mix-blend-mode: overlay;
    background-color: rgba(215, 95, 35, 0.42);
    background-blend-mode: overlay;
    filter: contrast(1.25) brightness(0.9);
    transform: translate(0.65px, 0.45px);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video-bg {
      display: none;
    }

    .hero-fallback-img.is-visible {
      opacity: 0.3;
    }
  }

  .hero-headline-line {
    white-space: nowrap;
  }

  .hero-a-slot {
    vertical-align: baseline;
  }

  .hero-a-slot-measure {
    visibility: hidden;
    grid-area: 1 / 1;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
  }

  .hero-a-viewport {
    grid-area: 1 / 1;
    display: flex;
    align-items: baseline;
    justify-content: center;
    overflow: hidden;
    line-height: inherit;
  }

  .hero-a-word {
    display: inline-block;
    line-height: inherit;
    will-change: transform, opacity, filter;
  }
</style>
