---
import '../styles/global.css';
import '../styles/theme-preview.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Preview — Minimal theme | The AMN',
  description = 'Design preview: warm white surfaces, dark anchors, lean minimal layout.',
} = Astro.props;

const siteName = 'the amn';
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#pillars', label: 'Pillars' },
  { href: '#how-we-work', label: 'Work' },
  { href: '#tech', label: 'Tech' },
  { href: '#services', label: 'Services' },
  { href: '#collective', label: 'Collective' },
  { href: '#contact', label: 'Connect' },
];
---

<!doctype html>
<html lang="en" class="theme-preview">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
  </head>
  <body class="theme-preview min-h-screen overflow-x-hidden pb-20 text-amn-brown">
    <header id="site-header" class="site-header is-scrolled fixed left-0 right-0 top-0 z-50 px-4 pt-3 transition-all duration-[600ms] ease-[cubic-bezier(0.22,1,0.36,1)] md:px-6">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4">
        <a href="#hero" class="shrink-0">
          <img
            id="header-logo"
            src="/assets/amn-logo-header-dark.png"
            alt="the amn"
            class="h-8 w-auto transition-opacity duration-[350ms] ease-[cubic-bezier(0.22,1,0.36,1)] md:h-9"
            width="160"
            height="48"
          />
        </a>

        <nav id="pill-nav" class="pill-nav pill-nav--light hidden md:inline-flex" aria-label="Main navigation">
          {navLinks.map((link) => (
            <a href={link.href} class="pill-nav-link">{link.label}</a>
          ))}
        </nav>

        <a href="#contact" class="pill-nav-link btn-primary hidden px-6 py-2.5 text-xs md:inline-flex">
          Connect
        </a>

        <button
          id="mobile-menu-btn"
          class="mobile-menu-btn inline-flex h-10 w-10 items-center justify-center rounded-full border backdrop-blur md:hidden"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <nav
        id="mobile-menu"
        class="mx-auto mt-3 hidden max-w-7xl flex-col gap-1 rounded-3xl border border-amn-brown/10 bg-white/95 p-4 backdrop-blur-xl md:hidden"
        aria-label="Mobile navigation"
      >
        {navLinks.map((link) => (
          <a href={link.href} class="pill-nav-link rounded-2xl px-4 py-3 font-caption text-sm uppercase tracking-wider text-amn-brown/80">
            {link.label}
          </a>
        ))}
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <aside class="preview-banner" aria-label="Preview mode">
      <span><strong>Preview</strong> · Apple gray / white</span>
      <a href="/">Live site →</a>
    </aside>

    <script>
      import { initAnimations } from '../scripts/animations';
      initAnimations();

      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      menuBtn?.addEventListener('click', () => {
        const isOpen = !mobileMenu?.classList.contains('hidden');
        mobileMenu?.classList.toggle('hidden');
        menuBtn.setAttribute('aria-expanded', String(!isOpen));
      });

      mobileMenu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('hidden');
          menuBtn?.setAttribute('aria-expanded', 'false');
        });
      });
    </script>
  </body>
</html>
